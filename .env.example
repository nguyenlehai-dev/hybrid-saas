# ============================================================
# Hybrid SaaS - Environment Configuration
# Copy this file to .env and update values
# ============================================================

# Domain
DOMAIN=nulith.io.vn
API_URL=https://api.nulith.io.vn
FRONTEND_URL=https://nulith.io.vn

# Database
DATABASE_URL=postgresql+asyncpg://saas_admin:CHANGE_ME@postgres:5432/hybrid_saas
DB_NAME=hybrid_saas
DB_USER=saas_admin
DB_PASS=CHANGE_ME

# Redis
REDIS_URL=redis://:CHANGE_ME@redis:6379/0
REDIS_PASS=CHANGE_ME

# JWT Authentication
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# VM2 AI Engine Connection
# Update with the actual IP/hostname of your VM2 (Docker AI Engine on Windows)
AI_ENGINE_URL=http://192.168.1.100:7860
AI_ENGINE_TIMEOUT=120

# File Storage
UPLOAD_DIR=/app/uploads
LANDING_PAGES_DIR=/app/landing-pages
MAX_UPLOAD_SIZE_MB=50

# App Settings
APP_NAME=Hybrid SaaS AI Platform
APP_ENV=production
DEBUG=false
LOG_LEVEL=info
WORKERS=4

# aaPanel API (optional - for Landing Page auto-deploy)
AAPANEL_URL=http://localhost:8888
AAPANEL_API_KEY=CHANGE_ME
